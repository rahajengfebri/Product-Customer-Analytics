    <worksheet name='Shipping ratio category'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Shipping Cost Ratio Category</run>
          </formatted-text>
        </title>
      </layout-options>
      <repository-location derived-from='https://public.tableau.com/workbooks/Tugas_bismillah/Shippingratiocategory?rev=' id='127180668' path='/workbooks/Tugas_bismillah' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Multiple Connections)' name='federated.1of0i720v6syuw1ahfro3087kmtf' />
          </datasources>
          <datasource-dependencies datasource='federated.1of0i720v6syuw1ahfro3087kmtf'>
            <column caption='Shipping Ratio' datatype='real' name='[Calculation_0640506978881544]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[shipping_charges] / [price]' />
            </column>
            <column caption='Shipping Cost Ratio Category' datatype='string' name='[Calculation_0640506979029001]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0640506978881544] &gt; { FIXED : PERCENTILE([Calculation_0640506978881544], 0.75) }&#13;&#10;THEN &quot;High Shipping (Top 25%)&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
            </column>
            <column caption='Geographic Segmentation' datatype='string' name='[Calculation_1371682633154563]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [payment_value] &lt; 85.36 THEN &quot;Very Low (Q1)&quot;&#13;&#10;ELSEIF [payment_value] &lt; 170.76 THEN &quot;Low-Medium (Q2)&quot;&#13;&#10;ELSEIF [payment_value] &lt; 336.06 THEN &quot;Medium-High (Q3)&quot;&#13;&#10;ELSE &quot;High (Top 25%)&quot;&#13;&#10;END' />
            </column>
            <column caption='AOV' datatype='real' name='[Calculation_1506921975250945]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([payment_value])/COUNTD([order_id])' />
            </column>
            <column-instance column='[Calculation_0640506979029001]' derivation='None' name='[none:Calculation_0640506979029001:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1371682633154563]' derivation='None' name='[none:Calculation_1371682633154563:nk]' pivot='key' type='nominal' />
            <column caption='Order Id' datatype='string' name='[order_id]' role='dimension' type='nominal' />
            <column caption='Payment Value' datatype='real' name='[payment_value]' role='measure' type='quantitative' />
            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
            <column caption='Shipping Charges' datatype='real' name='[shipping_charges]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1506921975250945]' derivation='User' name='[usr:Calculation_1506921975250945:qk]' pivot='key' type='quantitative' />
