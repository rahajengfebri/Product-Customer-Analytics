      <aliases enabled='yes' />
      <column caption='RFM Segmentation' datatype='string' name='[Calculation_0307904997634050]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1484382348165132] &gt;= 5 &#13;&#10;   AND [Calculation_1484382348812301] &gt;= 4 &#13;&#10;   AND [Calculation_1484382349111310] &gt;= 4 THEN &quot;Champion&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1484382348812301] &gt;= 4 &#13;&#10;   AND [Calculation_1484382349111310] &gt;= 4 THEN &quot;Loyal Customer&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1484382348165132] &gt;= 4 THEN &quot;Potential Loyalist&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1484382348165132] &lt;= 2 THEN &quot;At Risk&quot;&#13;&#10;&#13;&#10;ELSE &quot;Need Attention&quot;&#13;&#10;END' />
      </column>
      <column caption='MAU' datatype='datetime' name='[Calculation_0640506958700547]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [order_purchase_timestamp])' />
      </column>
      <column caption='Delivery Delay' datatype='integer' name='[Calculation_0640506973188101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,&#13;&#10;[order_estimated_delivery_date],&#13;&#10;[order_delivered_timestamp])' />
      </column>
      <column caption='Revenue' datatype='real' name='[Calculation_0640506974392326]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value])/COUNTD([customer_id])' />
      </column>
      <column caption='Delivery Delay Category' datatype='string' name='[Calculation_0640506976907271]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0640506973188101] &lt;= 0 THEN &quot;Early / On Time&quot;&#13;&#10;ELSEIF [Calculation_0640506973188101] &lt;= 7 THEN &quot;Late (1-7 days)&quot;&#13;&#10;ELSE &quot;Severely Late (&gt;7 days)&quot;&#13;&#10;END' />
      </column>
      <column caption='Shipping Ratio' datatype='real' name='[Calculation_0640506978881544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[shipping_charges] / [price]' />
      </column>
      <column caption='Shipping Cost Ratio Category' datatype='string' name='[Calculation_0640506979029001]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0640506978881544] &gt; { FIXED : PERCENTILE([Calculation_0640506978881544], 0.75) }&#13;&#10;THEN &quot;High Shipping (Top 25%)&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Median Shipping Ratio' datatype='real' name='[Calculation_0640506986033163]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([Calculation_0640506978881544])' />
      </column>
      <column caption='Price Category' datatype='string' name='[Calculation_0640506993836044]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price] &gt; { FIXED : PERCENTILE([price], 0.75) }&#13;&#10;THEN &quot;High Price&quot;&#13;&#10;ELSEIF [price] &lt;= { FIXED : PERCENTILE([price], 0.25) }&#13;&#10;THEN &quot;Low Price&quot;&#13;&#10;ELSE &quot;Mid Price&quot;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Transaction Hour' datatype='integer' name='[Calculation_0640507029213197]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [order_purchase_timestamp])' />
      </column>
      <column caption='DAU' datatype='datetime' name='[Calculation_0640507038248974]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;day&apos;, [order_purchase_timestamp])' />
      </column>
      <column caption='Kategorikal state' datatype='string' name='[Calculation_1371682611048448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [customer_state]&#13;&#10;    WHEN &quot;SP&quot; THEN &quot;São Paulo&quot;&#13;&#10;    WHEN &quot;RJ&quot; THEN &quot;Rio de Janeiro&quot;&#13;&#10;    WHEN &quot;MG&quot; THEN &quot;Minas Gerais&quot;&#13;&#10;    WHEN &quot;SC&quot; THEN &quot;Santa Catarina&quot;&#13;&#10;    WHEN &quot;ES&quot; THEN &quot;Espírito Santo&quot;&#13;&#10;    WHEN &quot;RN&quot; THEN &quot;Rio Grande do Norte&quot;&#13;&#10;    WHEN &quot;BA&quot; THEN &quot;Bahia&quot;&#13;&#10;    WHEN &quot;DF&quot; THEN &quot;Distrito Federal&quot;&#13;&#10;    WHEN &quot;RS&quot; THEN &quot;Rio Grande do Sul&quot;&#13;&#10;    WHEN &quot;PE&quot; THEN &quot;Pernambuco&quot;&#13;&#10;    WHEN &quot;GO&quot; THEN &quot;Goiás&quot;&#13;&#10;    WHEN &quot;CE&quot; THEN &quot;Ceará&quot;&#13;&#10;    WHEN &quot;PR&quot; THEN &quot;Paraná&quot;&#13;&#10;    WHEN &quot;MA&quot; THEN &quot;Maranhão&quot;&#13;&#10;    WHEN &quot;PI&quot; THEN &quot;Piauí&quot;&#13;&#10;    WHEN &quot;MT&quot; THEN &quot;Mato Grosso&quot;&#13;&#10;    WHEN &quot;MS&quot; THEN &quot;Mato Grosso do Sul&quot;&#13;&#10;    WHEN &quot;SE&quot; THEN &quot;Sergipe&quot;&#13;&#10;    WHEN &quot;RO&quot; THEN &quot;Rondônia&quot;&#13;&#10;    WHEN &quot;TO&quot; THEN &quot;Tocantins&quot;&#13;&#10;    WHEN &quot;AM&quot; THEN &quot;Amazonas&quot;&#13;&#10;    WHEN &quot;AP&quot; THEN &quot;Amapá&quot;&#13;&#10;    WHEN &quot;PB&quot; THEN &quot;Paraíba&quot;&#13;&#10;    WHEN &quot;PA&quot; THEN &quot;Pará&quot;&#13;&#10;    WHEN &quot;AL&quot; THEN &quot;Alagoas&quot;&#13;&#10;    ELSE [customer_state] // Tetap menampilkan kode jika ada yang tidak terdaftar&#13;&#10;END' />
      </column>
      <column caption='Brazil Region' datatype='string' name='[Calculation_1371682627768321]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [customer_state] IN (&quot;SP&quot;,&quot;RJ&quot;,&quot;MG&quot;,&quot;ES&quot;) THEN &quot;Southeast&quot;&#13;&#10;ELSEIF [customer_state] IN (&quot;RS&quot;,&quot;SC&quot;,&quot;PR&quot;) THEN &quot;South&quot;&#13;&#10;ELSEIF [customer_state] IN (&quot;GO&quot;,&quot;MT&quot;,&quot;MS&quot;,&quot;DF&quot;) THEN &quot;Midwest&quot;&#13;&#10;ELSEIF [customer_state] IN (&quot;BA&quot;,&quot;PE&quot;,&quot;CE&quot;,&quot;RN&quot;,&quot;PB&quot;,&quot;AL&quot;,&quot;SE&quot;,&quot;PI&quot;,&quot;MA&quot;) THEN &quot;Northeast&quot;&#13;&#10;ELSE &quot;North&quot;&#13;&#10;END' />
      </column>
      <column caption='Season Brazil' datatype='string' name='[Calculation_1371682628018178]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([order_purchase_timestamp]) IN (12,1,2,3) THEN &quot;Summer&quot;&#13;&#10;ELSEIF MONTH([order_purchase_timestamp]) IN (3,4,5,6) THEN &quot;Autumn&quot;&#13;&#10;ELSEIF MONTH([order_purchase_timestamp]) IN (6,7,8,9) THEN &quot;Winter&quot;&#13;&#10;ELSE &quot;Spring&quot;&#13;&#10;END' />
      </column>
      <column caption='Geographic Segmentation' datatype='string' name='[Calculation_1371682633154563]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [payment_value] &lt; 85.36 THEN &quot;Very Low (Q1)&quot;&#13;&#10;ELSEIF [payment_value] &lt; 170.76 THEN &quot;Low-Medium (Q2)&quot;&#13;&#10;ELSEIF [payment_value] &lt; 336.06 THEN &quot;Medium-High (Q3)&quot;&#13;&#10;ELSE &quot;High (Top 25%)&quot;&#13;&#10;END' />
      </column>
      <column caption='Recency' datatype='integer' name='[Calculation_1484382346645512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;    &apos;day&apos;,&#13;&#10;    { FIXED [customer_id] : MAX([order_purchase_timestamp]) },&#13;&#10;    { FIXED : MAX([order_purchase_timestamp]) }&#13;&#10;)' />
      </column>
      <column caption='Frequency' datatype='integer' name='[Calculation_1484382346907657]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : COUNTD([order_id]) }' />
      </column>
      <column caption='Monetary' datatype='real' name='[Calculation_1484382347087882]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : SUM([payment_value]) }' />
      </column>
      <column caption='Recency Score' datatype='integer' name='[Calculation_1484382348165132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1484382346645512] &lt;= 0.2 THEN 5&#13;&#10;ELSEIF [Calculation_1484382346645512] &lt;= 0.4 THEN 4&#13;&#10;ELSEIF [Calculation_1484382346645512] &lt;= 0.6 THEN 3&#13;&#10;ELSEIF [Calculation_1484382346645512] &lt;= 0.8 THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='Frequency Score' datatype='integer' name='[Calculation_1484382348812301]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1484382346907657] &gt;= 0.8 THEN 5&#13;&#10;ELSEIF [Calculation_1484382346907657] &gt;= 0.6 THEN 4&#13;&#10;ELSEIF [Calculation_1484382346907657] &gt;= 0.4 THEN 3&#13;&#10;ELSEIF [Calculation_1484382346907657] &gt;= 0.2 THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='Monetary Score' datatype='integer' name='[Calculation_1484382349111310]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1484382347087882] &gt;= 0.8 THEN 5&#13;&#10;ELSEIF [Calculation_1484382347087882] &gt;= 0.6 THEN 4&#13;&#10;ELSEIF [Calculation_1484382347087882] &gt;= 0.4 THEN 3&#13;&#10;ELSEIF [Calculation_1484382347087882] &gt;= 0.2 THEN 2&#13;&#10;ELSE 1&#13;&#10;END' />
      </column>
      <column caption='ARPU' datatype='real' name='[Calculation_1506921928818688]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value])/COUNTD([customer_id])' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_1506921975250945]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([payment_value])/COUNTD([order_id])' />
