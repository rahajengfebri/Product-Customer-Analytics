      <aliases enabled='yes' />
      <column caption='Promoter Flag' datatype='integer' name='[Calculation_1484382308528128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1484382328696837]=&quot;Promoter&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='CSAT' datatype='real' default-format='p0.00%' name='[Calculation_1484382308732929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1484382334005254])/COUNT([id])' />
      </column>
      <column caption='avg total score' datatype='real' name='[Calculation_1484382311391234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;[Inflight wifi service] +&#13;&#10;[Departure/Arrival time convenient] +&#13;&#10;[Ease of Online booking] +&#13;&#10;[Gate location] +&#13;&#10;[Food and drink] +&#13;&#10;[Online boarding] +&#13;&#10;[Seat comfort] +&#13;&#10;[Inflight entertainment] +&#13;&#10;[On-board service] +&#13;&#10;[Leg room service] +&#13;&#10;[Baggage handling] +&#13;&#10;[Checkin service] +&#13;&#10;[Inflight service] +&#13;&#10;[Cleanliness]&#13;&#10;) / 14' />
      </column>
      <column caption='Detractor Flag' datatype='integer' name='[Calculation_1484382313549827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1484382328696837]=&quot;Detractor&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='NPS' datatype='real' default-format='p0.0%' name='[Calculation_1484382313889796]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([Calculation_1484382308528128]) - SUM([Calculation_1484382313549827])&#13;&#10;) / COUNTD([id])' />
      </column>
      <column caption='NPS Category' datatype='string' name='[Calculation_1484382328696837]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1484382311391234] &gt;= 4 THEN &quot;Promoter&quot;&#13;&#10;ELSEIF [Calculation_1484382311391234] = 3 THEN &quot;Passive&quot;&#13;&#10;ELSE &quot;Detractor&quot;&#13;&#10;END' />
      </column>
      <column caption='satisfaction flag' datatype='integer' name='[Calculation_1484382334005254]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [satisfaction] = &quot;satisfied&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='sentiment' datatype='string' name='[Calculation_1484382334730247]' role='dimension' type='nominal'>
