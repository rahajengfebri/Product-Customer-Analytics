      <column caption='Spending Segment' datatype='string' name='[Calculation_1638039402680320]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [payment_value] &lt; 85.36 THEN &quot;Very Low&quot;&#13;&#10;ELSEIF [payment_value] &lt; 170.76 THEN &quot;Low-Medium&quot;&#13;&#10;ELSEIF [payment_value] &lt; 336.06 THEN &quot;Medium-High&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
