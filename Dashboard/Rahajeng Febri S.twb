            <column caption='Delivery Delay' datatype='integer' name='[Calculation_0640506973188101]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,&#13;&#10;[order_estimated_delivery_date],&#13;&#10;[order_delivered_timestamp])' />
