              <calculation class='tableau' formula='SUM([Calculation_1484382334005254])/COUNT([id])' />
            </column>
            <column caption='avg total score' datatype='real' name='[Calculation_1484382311391234]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;[Inflight wifi service] +&#13;&#10;[Departure/Arrival time convenient] +&#13;&#10;[Ease of Online booking] +&#13;&#10;[Gate location] +&#13;&#10;[Food and drink] +&#13;&#10;[Online boarding] +&#13;&#10;[Seat comfort] +&#13;&#10;[Inflight entertainment] +&#13;&#10;[On-board service] +&#13;&#10;[Leg room service] +&#13;&#10;[Baggage handling] +&#13;&#10;[Checkin service] +&#13;&#10;[Inflight service] +&#13;&#10;[Cleanliness]&#13;&#10;) / 14' />
            </column>
            <column caption='Detractor Flag' datatype='integer' name='[Calculation_1484382313549827]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1484382328696837]=&quot;Detractor&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='NPS' datatype='real' default-format='p0.0%' name='[Calculation_1484382313889796]' role='measure' type='quantitative'>
